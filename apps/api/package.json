{
  "name": "@menu/api",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "lint": "eslint src --ext .ts",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev --name init",
    "db:seed": "prisma db seed",
    "create-business-user": "tsx src/scripts/createBusinessUser.ts",
    "db:migrate:deploy": "prisma migrate deploy",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.637.0",
    "@menu/shared": "workspace:*",
    "@prisma/client": "^5.19.1",
    "argon2": "^0.41.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-async-errors": "^3.1.1",
    "helmet": "^7.1.0",
    "ioredis": "^5.4.1",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1",
    "nodemailer": "^6.9.14",
    "pg": "^8.12.0",
    "qrcode": "^1.5.4",
    "sanitize-html": "^2.13.0",
    "sharp": "^0.33.4",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/multer": "^1.4.11",
    "@types/node": "^22.3.0",
    "@types/nodemailer": "^6.4.15",
    "@types/pg": "^8.20.0",
    "@types/qrcode": "^1.5.5",
    "@types/sanitize-html": "^2.16.1",
    "@types/supertest": "^6.0.2",
    "prisma": "^5.19.1",
    "supertest": "^7.0.0",
    "tsx": "^4.17.1",
    "vitest": "^2.1.1"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  }
}
